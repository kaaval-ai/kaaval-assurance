# kaaval-assurance environment template. Copy to .env, fill in, never commit .env.
# Every value below is a placeholder; model id and family are telemetry fields,
# not marketing claims.

## Local tier: Gemma-first via vLLM on the AMD hackathon GPU pod
VLLM_BASE_URL=http://localhost:8000/v1
# Preferred: a Gemma model that fits the ~48 GB pod GPU. Decide after running
# the runtime probe; use a non-Gemma model only as an operational fallback and
# update VLLM_MODEL_FAMILY truthfully if you do.
VLLM_MODEL=<chosen local model>
VLLM_MODEL_FAMILY=gemma
VLLM_HARDWARE_TARGET=amd-hackathon-gpu
VLLM_TIMEOUT_SECONDS=60
VLLM_DTYPE=bfloat16
VLLM_KV_CACHE_DTYPE=fp8
VLLM_ENABLE_PREFIX_CACHING=true
# The hackathon FAQ example serves with --gpu-memory-utilization 0.3 on the pod.
VLLM_GPU_MEMORY_UTILIZATION=0.3
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_STRUCTURED_OUTPUTS=true
#VLLM_API_KEY=
#VLLM_ROCM_VERSION=
#VLLM_VERSION=
#VLLM_MAX_CONTEXT_TOKENS=
#VLLM_COST_PER_PROMPT_TOKEN=0
#VLLM_COST_PER_COMPLETION_TOKEN=0

## Remote escalation + Layer 3 challenger: Fireworks AI
FIREWORKS_API_KEY=<your fireworks api key>
# Use a model from the event credit allocation (the FAQ mentions Kimi and
# MiniMax endpoints); do not assume an arbitrary default model is eligible.
FIREWORKS_MODEL=<fireworks model from event allocation>
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=60
#FIREWORKS_COST_PER_PROMPT_TOKEN=
#FIREWORKS_COST_PER_COMPLETION_TOKEN=
#FIREWORKS_AUDIT_MODEL=
FIREWORKS_AUDIT_TEMPERATURE=0
FIREWORKS_AUDIT_MAX_TOKENS=1024
#FIREWORKS_AUDIT_TOP_K=
#FIREWORKS_AUDIT_LOGPROBS=
#FIREWORKS_AUDIT_TOP_LOGPROBS=
#FIREWORKS_AUDIT_PROMPT_CACHE_KEY=
#FIREWORKS_AUDIT_PROMPT_CACHE_ISOLATION_KEY=
#FIREWORKS_AUDIT_THINKING_BUDGET_TOKENS=

## Budget guardrail used by scripts/
# Scripts that spend Fireworks credits refuse to run unless this is set to 1.
KAAVAL_CONFIRM_SPEND=0
