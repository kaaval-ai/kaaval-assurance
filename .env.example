# kaaval-assurance environment template. Copy to .env, fill in, never commit .env.
# All values below are empty or placeholders; model id and family are telemetry
# fields, not marketing claims.

## Remote escalation + Layer 3 challenger: Fireworks AI
FIREWORKS_API_KEY=
# Set to a Kimi or MiniMax model available in the event credit allocation.
FIREWORKS_MODEL=
FIREWORKS_AUDIT_MODEL=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_TIMEOUT_SECONDS=60
FIREWORKS_AUDIT_TEMPERATURE=0
FIREWORKS_AUDIT_MAX_TOKENS=1024
# Required for paid Fireworks runs. Values are USD per token, not per million.
# Verify current model pricing before setting these. For GLM 5.2 standard,
# Fireworks listed $1.40/M input and $4.40/M output on 2026-07-10.
FIREWORKS_COST_PER_PROMPT_TOKEN=
FIREWORKS_COST_PER_COMPLETION_TOKEN=
#FIREWORKS_AUDIT_TOP_K=
#FIREWORKS_AUDIT_LOGPROBS=
#FIREWORKS_AUDIT_TOP_LOGPROBS=
#FIREWORKS_AUDIT_PROMPT_CACHE_KEY=
#FIREWORKS_AUDIT_PROMPT_CACHE_ISOLATION_KEY=
#FIREWORKS_AUDIT_THINKING_BUDGET_TOKENS=

## Local tier: Gemma-first via vLLM on the AMD hackathon GPU pod
VLLM_BASE_URL=http://localhost:8000/v1
# Preferred: a Gemma model that fits the ~48 GB pod GPU together with vLLM
# runtime and KV cache overhead. Decide after running the runtime probe; use a
# non-Gemma model only as an operational fallback and update
# VLLM_MODEL_FAMILY truthfully if you do.
VLLM_MODEL=
VLLM_MODEL_FAMILY=gemma
VLLM_HARDWARE_TARGET=amd-hackathon-gpu
VLLM_ROCM_VERSION=
VLLM_VERSION=
VLLM_TIMEOUT_SECONDS=60
VLLM_DTYPE=bfloat16
VLLM_KV_CACHE_DTYPE=auto
VLLM_ENABLE_PREFIX_CACHING=true
# The hackathon FAQ example serves with --gpu-memory-utilization 0.3.
VLLM_GPU_MEMORY_UTILIZATION=0.30
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_STRUCTURED_OUTPUTS=true
#VLLM_API_KEY=
#VLLM_MAX_CONTEXT_TOKENS=
#VLLM_COST_PER_PROMPT_TOKEN=0
#VLLM_COST_PER_COMPLETION_TOKEN=0

## Local dev comparison/fallback tier: Ollama (OpenAI-compatible /v1)
# Gemma is the preferred family for the hackathon story; Qwen is a local
# comparison/fallback only. The AMD vLLM Gemma tier is the final Track 3
# proof target — Ollama runs never claim AMD runtime (hardware target stays
# local-mac-ollama).
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=gemma4:12b
OLLAMA_MODEL_FAMILY=gemma
OLLAMA_TIMEOUT_SECONDS=120
# Structured outputs off by default until tested against your Ollama build.
OLLAMA_STRUCTURED_OUTPUTS=false
# Optional second candidate for the model comparison helper:
#OLLAMA_QWEN_MODEL=qwen2:7b

## Budget guardrail used by scripts/
# Scripts that spend Fireworks credits refuse to run unless this is set to 1.
KAAVAL_CONFIRM_SPEND=0

## Flight Deck runtime onboarding
# local: Ollama/vLLM through host.docker.internal plus Fireworks BYOK.
# hosted: Fireworks BYOK; custom HTTPS endpoints require the separate gate.
KAAVAL_DEPLOYMENT_MODE=local
KAAVAL_LIVE_RUNS_ENABLED=1
KAAVAL_ALLOW_BYOK=1
KAAVAL_ALLOW_CUSTOM_ENDPOINTS=0
# Optional comma-separated hostnames for trusted local/container runtimes.
KAAVAL_RUNTIME_HOST_ALLOWLIST=

## Flight Deck API operator gates (default closed)
# Client confirm_spend is only an acknowledgment; this server-side flag is the
# operator authorization for paid Fireworks execution. Never enable publicly.
KAAVAL_ALLOW_PAID_REMOTE=0
# API exports are disabled by default. When enabled for a private/local demo,
# each run writes under artifacts/live-exports/<run-id>/ and cannot replace the
# curated top-level AMD evidence bundle.
KAAVAL_ALLOW_ARTIFACT_EXPORT=0
# Rejected raw model output is redacted from API receipts unless both the
# caller requests diagnostics and this private/operator gate is enabled.
KAAVAL_ALLOW_DIAGNOSTIC_RAW=0
